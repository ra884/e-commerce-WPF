<Page x:Class="e_commerce_WPF.LogIn"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:e_commerce_WPF"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="LogIn">

    <Grid>
        <Grid.Background>
            <ImageBrush ImageSource="C:\Users\hp\source\repos\e-commerce WPF\e-commerce WPF\black-friday-sales-sign-neon-light_23-2151833076.avif"></ImageBrush>
        </Grid.Background>
        <StackPanel>
            <TextBlock Foreground="White" Margin="30"  HorizontalAlignment="Center" FontWeight="Bold" FontSize="70">Sign In</TextBlock>
            <StackPanel Margin="50 0 0 0" Orientation="Horizontal">
                <Label Foreground="White" FontSize="20">Email</Label>
                <TextBox BorderThickness="2" BorderBrush="Black" Margin="90 0 0 0" Name="mail" Width="600"></TextBox>
            </StackPanel>
            <StackPanel Margin="50 30 0 0" Orientation="Horizontal">
                <Label Foreground="White" FontSize="20">Password</Label>
                <PasswordBox BorderThickness="2" BorderBrush="Black" Margin="55 0 0 0"  Name="pass" Width="600"></PasswordBox>
            </StackPanel>
            <Button Width="150" HorizontalAlignment="Center" BorderThickness="2" BorderBrush="Black" Margin="0 50 0 0" Height="50" Background="White" FontSize="20" FontWeight="Bold" Click="Button_Click">Sign In</Button>
            <Button Width="100" Height="50">to home</Button>
        </StackPanel>
    </Grid>
</Page>
