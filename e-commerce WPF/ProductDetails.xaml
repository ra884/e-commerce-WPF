<Page x:Class="e_commerce_WPF.ProductDetails"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:e_commerce_WPF"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="ProductDetails">

    <Grid>
        <Grid.Background>
            <ImageBrush ImageSource="C:\Users\hp\source\repos\e-commerce WPF\e-commerce WPF\black-friday-sales-sign-neon-light_23-2151833076.avif"></ImageBrush>
        </Grid.Background>
        <StackPanel >
        
            <TextBlock FontSize="50" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" Margin="30">Product Details</TextBlock>
            <StackPanel Margin="0 30">
                <StackPanel Orientation="Horizontal">
                    <TextBlock  FontSize="20" Foreground="White" Margin="50 0 0 0">Name :</TextBlock>
                    <TextBox VerticalAlignment="Center" FontSize="15" Name="title" Width="300" Height="30" Margin="150 0 0 0"></TextBox>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock  FontSize="20" Foreground="White" Margin="50 20 0 0">Price :</TextBlock>
                    <TextBox VerticalAlignment="Center" FontSize="15" Name="price" Width="300" Height="30" Margin="160 20 0 0"></TextBox>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock FontSize="20" Foreground="White" Margin="50 20 0 0">Description :</TextBlock>
                    <TextBox VerticalAlignment="Center" FontSize="15" Name="desc" Width="300" Height="30" Margin="102 20 0 0"></TextBox>
                </StackPanel>
                </StackPanel>
            <StackPanel Orientation="Horizontal">
            <Button Width="150" Margin="200 50 0 0" Height="40" Background="White" FontSize="17" FontWeight="Bold" Click="Button_Click">Add to cart</Button>
            <Button Width="150" Margin="70 50 0 0 " Height="40" Background="White" FontSize="17" FontWeight="Bold" Click="view">View cart</Button>
            </StackPanel>
        </StackPanel>
    </Grid>
</Page>
