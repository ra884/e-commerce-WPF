<Page x:Class="e_commerce_WPF.ShoppingCart"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:e_commerce_WPF"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="ShoppingCart">

    <Grid>
        <Grid.Background>
            <ImageBrush ImageSource="C:\Users\hp\source\repos\e-commerce WPF\e-commerce WPF\black-friday-sales-sign-neon-light_23-2151833076.avif"></ImageBrush>
        </Grid.Background>
        <StackPanel>
            <TextBlock FontSize="50" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" Margin="30">Shopping Cart</TextBlock>
            <ListBox Name="items" Width="500" Height="200">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" Margin="5">
                            <TextBlock Text="{Binding Product.Name}" Width="200"/>
                            <TextBlock Text="{Binding Quantity}" Width="100"/>
                            <TextBlock Text="{Binding Product.Price}" Width="100"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
            <StackPanel Orientation="Horizontal">
            <TextBlock FontSize="30" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" Margin="200 20 0 0"  Width="100" >Total : </TextBlock>
                <Label Foreground="White" FontSize="30" Margin="20 20 0 0" Name="l_total" Width="200" />
            </StackPanel>
            <Button Width="150" Margin="0 0 70 0" HorizontalAlignment="Right" FontWeight="Bold" FontSize="15" Height="40" Click="Button_Click" >Remove</Button>
        </StackPanel>
    </Grid>
</Page>
