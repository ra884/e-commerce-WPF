<Page x:Class="e_commerce_WPF.ProductFilter"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:e_commerce_WPF"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="ProductFilter">

    <Grid>
        <Grid.Background>
            <ImageBrush ImageSource="C:\Users\hp\source\repos\e-commerce WPF\e-commerce WPF\black-friday-sales-sign-neon-light_23-2151833076.avif"></ImageBrush>
        </Grid.Background>
        <StackPanel>
            <TextBlock Foreground="White" Margin="30" FontWeight="Bold" HorizontalAlignment="Center" FontSize="50">Filter Products</TextBlock>
            <StackPanel Orientation="Horizontal">
                <TextBlock Foreground="White" Margin="50 -10 0 0"   FontSize="20">Category</TextBlock>
                <ComboBox Name="combo" Margin="40 -5 0 0" Width="200"></ComboBox>
            </StackPanel>
            <CheckBox Name="check" Foreground="White" VerticalContentAlignment="Center" FontSize="20" Margin="50 100 0 0">Available products only</CheckBox>
            <TextBlock Foreground="White" Margin="50 30 0 0" FontSize="20">Sort by :</TextBlock>
            <RadioButton Name="price" Foreground="White" GroupName="radio" Margin="30 10 0 0" VerticalAlignment="Center" VerticalContentAlignment="Center"  FontSize="20">Price</RadioButton>
            <RadioButton Name="name" Foreground="White" GroupName="radio" Margin="30 10 0 0" VerticalAlignment="Center" VerticalContentAlignment="Center"   FontSize="20">Name</RadioButton>
            <Button Width="200" Height="30" FontWeight="Bold" Background="White" FontSize="20" Click="Button_Click">Filter</Button>
        </StackPanel>
    </Grid>

</Page>
