<Page x:Class="e_commerce_WPF.ProductList"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:e_commerce_WPF"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="ProductList">

    <Grid>
        <Grid.Background>
            <ImageBrush ImageSource="C:\Users\hp\source\repos\e-commerce WPF\e-commerce WPF\black-friday-sales-sign-neon-light_23-2151833076.avif"></ImageBrush>
        </Grid.Background>
        <StackPanel>
        <TextBlock Foreground="White" Margin="30" FontWeight="Bold" HorizontalAlignment="Center" FontSize="50">Products List</TextBlock>
            <ListBox Name="products" Width="500" Height="200">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Width="200" Text="{Binding Name}" FontSize="20"></TextBlock>
                            <TextBlock Width="200" Text="{Binding Price}" FontSize="20"></TextBlock>
                            <Image Width="100" Source="{Binding ImagePath}"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
            <Button Margin="0 40" Width="150" Height="50" Background="White" FontWeight="Bold" FontSize="15" Click="Button_Click">View Details</Button>
        </StackPanel>
    </Grid>
</Page>
